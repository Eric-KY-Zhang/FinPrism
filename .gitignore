# ============================================================
# 历史备份 (本地保留, 不入库以控制仓库体积)
# ============================================================
archive/

# release/ 入库 (v1.0_release.xlsm + v1.0_source.xlsm), 仅排除其内部 cache
release/.cache/

# ============================================================
# 测试 / 调试产物
# ============================================================
test_outputs/
xlsm_temp/
temp_archive.zip
*.bak
*.bak_*

# Phase 4f 回归 dump
samples/regression_phase4f_*.json
# Phase 4g stockanalysis HTML 调研样本 (按需本地留存)
samples/stockanalysis_*.html

# ============================================================
# Python 运行产物
# ============================================================
__pycache__/
*.pyc
*.pyo
*.pyd

# ============================================================
# 本地缓存 (HTTP 24h cache, 含雪球 cookie 风险)
# ============================================================
.cache/

# ============================================================
# 编辑器 / 工具临时文件
# ============================================================
.claude/
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# Excel 临时锁文件
~$*.xlsm
~$*.xlsx
